{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Backend API",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/modelmatrix_backend/cmd/api/main.go",
            "cwd": "${workspaceFolder}/modelmatrix_backend",
            "env": {},
            "args": []
        },
        {
            "name": "Launch Migrate",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/modelmatrix_backend/cmd/migrate/main.go",
            "cwd": "${workspaceFolder}/modelmatrix_backend",
            "env": {},
            "args": []
        },
        {
            "name": "Launch Migrate (Fresh)",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/modelmatrix_backend/cmd/migrate/main.go",
            "cwd": "${workspaceFolder}/modelmatrix_backend",
            "env": {},
            "args": ["-drop"]
        }
    ]
}

